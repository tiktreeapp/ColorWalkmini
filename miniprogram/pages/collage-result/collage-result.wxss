page {
  background: #f7f7f7;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.result-image {
  width: 100%;
  border-radius: 16rpx;
}

.empty {
  height: 600rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #666;
  background: #fff;
  border-radius: 16rpx;
}

.save-btn {
  margin-top: 20rpx;
  background: #111;
  color: #fff;
  border-radius: 14rpx;
}

.meta-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #fff;
}

.meta-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.meta-label {
  color: #666;
  font-size: 26rpx;
}

.meta-value {
  font-size: 30rpx;
  color: #111;
  letter-spacing: 2rpx;
}

.meta-right {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-pin {
  font-size: 22rpx;
}

.meta-city {
  font-size: 22rpx;
  color: #111;
}

.privacy-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  z-index: 40;
}

.privacy-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 28rpx;
  box-sizing: border-box;
}

.privacy-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #111;
}

.privacy-copy {
  display: block;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #555;
}

.privacy-link {
  color: #2f9b59;
}

.privacy-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 26rpx;
}

.privacy-btn {
  flex: 1;
  border-radius: 14rpx;
  font-size: 26rpx;
  line-height: 2.1;
}

.privacy-btn.secondary {
  background: #f5f5f5;
  color: #222;
}

.privacy-btn.primary {
  background: #111;
  color: #fff;
}
