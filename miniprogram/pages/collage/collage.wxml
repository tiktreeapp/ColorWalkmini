<view class="page-root">
  <scroll-view class="page" scroll-y>
    <view class="section">
      <view class="inline-field">
        <text class="inline-label">颜色</text>
        <view class="inline-control color-control">
          <view class="chip" style="background: {{palette[selectedColorIndex].hex}};"></view>
          <text class="color-name">{{palette[selectedColorIndex].name}}</text>
          <picker mode="selector" range="{{palette}}" range-key="name" value="{{selectedColorIndex}}" bindchange="onPickColor">
            <view class="picker-trigger">▼</view>
          </picker>
        </view>
      </view>

      <view class="inline-field">
        <text class="inline-label">心情</text>
        <view class="inline-control mood-control">
          <text class="mood-display">{{moodGroups[selectedMoodGroupIndex].display}}</text>
          <picker mode="selector" range="{{moodGroups}}" range-key="display" value="{{selectedMoodGroupIndex}}" bindchange="onPickMoodGroup">
            <view class="picker-trigger">▼</view>
          </picker>
        </view>
      </view>

      <view class="inline-field template-field">
        <text class="inline-label">模版</text>
        <view class="template-row compact">
          <block wx:for="{{templates}}" wx:key="id">
            <view class="template-item {{selectedTemplateId === item.id ? 'active' : ''}}" data-id="{{item.id}}" bindtap="onTemplateSelect">{{item.label}}</view>
          </block>
        </view>
      </view>

      <view class="slot-board slot-template-{{selectedTemplateId}}">
        <block wx:for="{{slots}}" wx:key="index">
          <view class="slot-item slot-item-{{selectedTemplateId}} {{swapSourceIndex === item.index ? 'swap-selected' : ''}}" data-index="{{item.index}}" bindtap="onPickSlotImage" bindlongpress="onSlotLongPress">
            <image wx:if="{{item.path}}" src="{{item.path}}" mode="aspectFill" class="slot-image"></image>
            <view wx:else class="slot-empty">
              <text class="slot-plus">+</text>
              <text class="slot-tip">选择照片</text>
            </view>
          </view>
        </block>
      </view>

    </view>

    <canvas canvas-id="composeCanvas" class="compose-canvas"></canvas>
    <canvas canvas-id="resizeCanvas" class="resize-canvas"></canvas>
  </scroll-view>

  <view class="action-bar">
    <button class="action-btn" bindtap="onChooseImages" disabled="{{uploading}}">{{uploading ? '上传中...' : '多图上传'}}</button>
    <button class="action-btn" bindtap="onComposeImage" disabled="{{uploading}}">生成拼图</button>
  </view>

  <view class="privacy-mask" wx:if="{{privacyPopupVisible}}">
    <view class="privacy-card">
      <text class="privacy-title">用户隐私保护提示</text>
      <view class="privacy-copy">
        <text>为实现照片拼图选择图片与保存到相册功能，需要你先阅读并同意</text>
        <text class="privacy-link" bindtap="onOpenPrivacyContract">《用户隐私保护指引》</text>
        <text>。</text>
      </view>
      <view class="privacy-actions">
        <button class="privacy-btn secondary" bindtap="onDeclinePrivacy">暂不同意</button>
        <button class="privacy-btn primary" bindtap="onAgreePrivacy">同意并继续</button>
      </view>
    </view>
  </view>
</view>
