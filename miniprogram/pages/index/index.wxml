<scroll-view class="page" scroll-y>
  <view class="section">
    <text class="section-title">小决定转盘</text>
    <view class="wheel-wrap">
      <canvas canvas-id="wheelCanvas" class="wheel-canvas"></canvas>
      <button class="spin-btn" bindtap="onSpinStart" disabled="{{spinning}}">{{spinning ? '转动中...' : '开始转动'}}</button>
    </view>
    <text class="result">{{wheelResult}}</text>
  </view>

  <view class="section">
    <text class="section-title">照片拼图</text>

    <view class="field">
      <text class="label">七彩色卡</text>
      <picker mode="selector" range="{{palette}}" range-key="name" value="{{selectedColorIndex}}" bindchange="onPickColor">
        <view class="picker-line">
          <view class="chip" style="background: {{palette[selectedColorIndex].hex}};"></view>
          <text>{{palette[selectedColorIndex].name}}</text>
        </view>
      </picker>
    </view>

    <view class="field">
      <text class="label">当下心情</text>
      <input class="mood-input" value="{{moodText}}" bindinput="onMoodInput" maxlength="32" />
    </view>

    <view class="field">
      <text class="label">模版选择</text>
      <view class="template-row">
        <block wx:for="{{templates}}" wx:key="id">
          <view class="template-item {{selectedTemplateId === item.id ? 'active' : ''}}" data-id="{{item.id}}" bindtap="onTemplateSelect">{{item.label}}</view>
        </block>
      </view>
    </view>

    <view class="btn-row">
      <button class="action-btn" bindtap="onChooseImages">上传图片</button>
      <button class="action-btn" bindtap="onComposeImage">生成拼图</button>
      <button class="action-btn" bindtap="onSaveImage">保存相册</button>
    </view>

    <view class="thumbs" wx:if="{{uploadedImages.length}}">
      <image wx:for="{{uploadedImages}}" wx:key="*this" src="{{item}}" mode="aspectFill" class="thumb"></image>
    </view>

    <view class="output" wx:if="{{composedImagePath}}">
      <image src="{{composedImagePath}}" mode="widthFix" class="output-image"></image>
    </view>
  </view>

  <canvas canvas-id="composeCanvas" class="compose-canvas"></canvas>
</scroll-view>
