page {
  background: #f7f7f7;
  color: #111;
}

.page {
  height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
}

.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
  display: block;
}

.wheel-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wheel-canvas {
  width: 560rpx;
  height: 560rpx;
}

.spin-btn {
  margin-top: 12rpx;
  width: 300rpx;
  background: #111;
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.result {
  margin-top: 18rpx;
  display: block;
  text-align: center;
  font-size: 30rpx;
  color: #333;
}

.field {
  margin-bottom: 22rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.picker-line {
  height: 84rpx;
  border-radius: 14rpx;
  border: 1rpx solid #e8e8e8;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  font-size: 30rpx;
}

.chip {
  width: 34rpx;
  height: 34rpx;
  border-radius: 8rpx;
  margin-right: 14rpx;
}

.mood-input {
  height: 84rpx;
  border-radius: 14rpx;
  border: 1rpx solid #e8e8e8;
  padding: 0 20rpx;
  font-size: 30rpx;
}

.template-row {
  display: flex;
  gap: 12rpx;
}

.template-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 14rpx;
  border: 1rpx solid #e8e8e8;
  font-size: 28rpx;
}

.template-item.active {
  background: #111;
  color: #fff;
  border-color: #111;
}

.btn-row {
  display: flex;
  gap: 12rpx;
  margin-top: 10rpx;
}

.action-btn {
  flex: 1;
  font-size: 26rpx;
  border-radius: 12rpx;
  background: #fff;
  border: 1rpx solid #dcdcdc;
  line-height: 2.2;
}

.thumbs {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.thumb {
  width: 100%;
  height: 180rpx;
  border-radius: 10rpx;
}

.output {
  margin-top: 18rpx;
}

.output-image {
  width: 100%;
  border-radius: 14rpx;
}

.compose-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 1080rpx;
  height: 1440rpx;
}
