<view class="page" style="background: {{bgColor}};">
  <canvas
    canvas-id="mixCanvas"
    class="mix-canvas"
    bindtouchstart="onTouchStart"
    bindtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
    bindtap="onCanvasTap"
  ></canvas>
  
  <!-- 文本颜色手势引导 -->
  <cover-view class="text-color-guide" wx:if="{{showTextColorGuide}}">
    <cover-view class="guide-box">
      <cover-view class="guide-icon">↑</cover-view>
      <cover-view class="guide-text">滑动文本切换颜色</cover-view>
    </cover-view>
  </cover-view>

  <view class="bottom-bar">
    <view class="bar-left">
      <view class="btn palette-btn {{paletteVisible ? 'active' : ''}}" bindtap="onTogglePalette" aria-label="色盘">
        <view class="palette-inner" style="background: {{solidColor}}; border-color: rgba(255,255,255,1);"></view>
      </view>

      <block wx:for="{{mainColors}}" wx:key="*this">
        <view 
          class="btn swatch main-swatch {{item === solidColor ? 'active' : ''}}" 
          style="background: {{item}};" 
          data-color="{{item}}" 
          bindtap="onPickColor"
        ></view>
      </block>
    </view>

    <view class="bar-right">
      <view class="btn download-btn" bindtap="onDownload">保存</view>
    </view>
  </view>

  <cover-view class="float-picker" wx:if="{{eyedropper}}" style="left: {{eyedropperPos.x}}px; top: {{eyedropperPos.y}}px;">
    <cover-view class="picker-tip">点击或拖拽选取颜色</cover-view>
    <cover-view class="picker-inner" style="border-color: {{solidColor}};">
      <cover-view class="picker-dot" style="background: {{solidColor}};"></cover-view>
    </cover-view>
    <cover-view class="picker-close" bindtap="onToggleEyedropper">退出拾色</cover-view>
  </cover-view>

  <!-- 调色盘：必须使用 cover-view 才能盖在 canvas 之上 -->
  <cover-view class="palette-mask" wx:if="{{paletteVisible}}" bindtap="onTogglePalette">
    <cover-view class="palette-sheet" catchtap="noop">
      <cover-view class="sheet-head">
        <cover-view class="sheet-title">调色盘</cover-view>
        <cover-view class="sheet-tools">
          <cover-view class="tool-icon-btn" bindtap="onToggleEyedropper">
             <cover-image class="eyedropper-icon-img" src="{{eyedropper ? '/assets/tab/xiguan-active.png' : '/assets/tab/xiguan.png'}}" />
          </cover-view>
        </cover-view>
      </cover-view>

      <!-- 已存颜色：长方形色块，带色值显示 -->
      <cover-view class="history-wrap" wx:if="{{historyColors.length > 0}}">
        <cover-view class="history-title">已存颜色</cover-view>
        <cover-view class="history-grid">
          <cover-view 
            class="history-item" 
            wx:for="{{historyColors}}" 
            wx:key="*this"
            style="background: {{item}};"
            data-color="{{item}}"
            bindtap="onPickColor"
          >
            <cover-view class="history-hex">{{item}}</cover-view>
          </cover-view>
        </cover-view>
      </cover-view>

      <!-- 推荐颜色：圆形色块 -->
      <cover-view class="history-wrap">
        <cover-view class="history-title">推荐颜色</cover-view>
        <cover-view class="sheet-grid">
          <block wx:for="{{commonColors}}" wx:key="*this">
            <cover-view class="grid-color" style="background: {{item}};" data-color="{{item}}" bindtap="onPickColor"></cover-view>
          </block>
        </cover-view>
      </cover-view>
    </cover-view>
  </cover-view>

  <canvas canvas-id="analyzeCanvas" class="hidden-canvas" style="width: 96px; height: 72px;"></canvas>
  <canvas
    canvas-id="cropCanvas"
    class="hidden-canvas"
    style="width: 1080px; height: 810px;"
    width="1080"
    height="810"
  ></canvas>
  <canvas
    canvas-id="exportCanvas"
    class="hidden-canvas"
    style="width: 1080px; height: 1440px;"
    width="1080"
    height="1440"
  ></canvas>
</view>
