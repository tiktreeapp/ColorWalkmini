page {
  background: #2f7dae;
}

.page {
  height: 100vh;
  position: relative;
  overflow: hidden;
}

.mix-canvas {
  width: 100%;
  height: calc(100vh - 168px);
}

.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 10px;
  height: 10px;
}

.bottom-bar {
  position: fixed;
  left: 18px;
  right: 18px;
  bottom: calc(72px + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  z-index: 10;
}

.bar-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.bar-right {
  display: flex;
  align-items: center;
  gap: 10px;
}

.btn {
  user-select: none;
}

.palette-btn {
  width: 42px;
  height: 42px;
  border-radius: 999px;
  background: linear-gradient(135deg, #ff4d4f, #ffb300, #ffee58, #4caf50, #00bcd4, #3f51b5, #9c27b0);
  box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12);
  border: 2px solid rgba(255, 255, 255, 0.9);
}

.swatch {
  width: 42px;
  height: 42px;
  border-radius: 999px;
  border: 2px solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12);
}

.main-swatch {
  border-width: 2px;
}

.swatch.active {
  box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.9), 0 10px 18px rgba(0, 0, 0, 0.15);
}

.download-btn {
  padding: 0 14px;
  height: 42px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.9);
  color: #111;
  font-size: 14px;
}

.palette-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.25);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 16px;
  box-sizing: border-box;
  z-index: 200;
}

.palette-sheet {
  width: 100%;
  max-width: 520px;
  background: #fff;
  border-radius: 18px;
  padding: 16px;
  box-sizing: border-box;
  z-index: 201;
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 12px;
}

.sheet-title {
  font-size: 14px;
  color: #111;
  font-weight: 600;
}

.sheet-tools {
  display: flex;
  align-items: center;
  gap: 8px;
}

.tool-pill {
  height: 32px;
  padding: 0 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  background: #f2f2f2;
  color: #111;
  font-size: 12px;
}

.tool-pill.active {
  background: #111;
  color: #fff;
}

.sheet-grid {
  display: flex;
  flex-wrap: wrap;
  margin-right: -10px;
}

.picker-wrap {
  margin-bottom: 14px;
}

.picker-sv {
  position: relative;
  width: 100%;
  height: 168px;
  border-radius: 14px;
  overflow: hidden;
}

.sv-white {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(90deg, #ffffff, rgba(255, 255, 255, 0));
}

.sv-black {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(0deg, #000000, rgba(0, 0, 0, 0));
}

.sv-thumb {
  position: absolute;
  width: 18px;
  height: 18px;
  border-radius: 999px;
  border: 2px solid rgba(255, 255, 255, 0.95);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
  transform: translate(-50%, -50%);
}

.picker-hue {
  margin-top: 10px;
  position: relative;
  width: 100%;
  height: 16px;
  border-radius: 999px;
  overflow: hidden;
  background: linear-gradient(
    90deg,
    #ff0000,
    #ffff00,
    #00ff00,
    #00ffff,
    #0000ff,
    #ff00ff,
    #ff0000
  );
}

.hue-thumb {
  position: absolute;
  top: 50%;
  width: 18px;
  height: 18px;
  border-radius: 999px;
  border: 2px solid rgba(255, 255, 255, 0.95);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
  transform: translate(-50%, -50%);
}

.grid-color {
  width: 28px;
  height: 28px;
  margin: 0 10px 10px 0;
  border-radius: 999px;
  border: 1px solid rgba(0, 0, 0, 0.08);
}

.sheet-tip {
  margin-top: 14px;
  font-size: 12px;
  color: #666;
}
