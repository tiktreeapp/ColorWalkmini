page {
  background: #f7f7f7;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.mini-tip-banner {
  position: relative;
  width: 100%;
  height: 36px;
  margin-bottom: 12rpx;
  padding: 0 28rpx;
  border-radius: 24rpx;
  border: 1rpx solid #dcdcdc;
  background: #ffffff;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 38rpx;
  font-weight: 700;
  display: block;
  color: #111;
}

.mini-tip-close {
  margin-left: auto;
  width: 20rpx;
  height: 20rpx;
  font-size: 16rpx;
  line-height: 20rpx;
  text-align: center;
  color: #888;
}

.mini-tip-copy {
  font-size: 14px;
  line-height: 1;
  color: #6b6b6b;
}

.mini-tip-capsule {
  display: inline-flex;
  align-items: center;
  width: 34rpx;
  height: 18rpx;
  margin: 0 8rpx;
  padding: 0 4rpx;
  border: 1rpx solid #bdbdbd;
  border-radius: 999rpx;
  box-sizing: border-box;
}

.mini-tip-capsule-left {
  display: inline-flex;
  align-items: center;
  gap: 2rpx;
  padding-right: 4rpx;
}

.mini-tip-capsule-divider {
  width: 1rpx;
  height: 10rpx;
  background: #bdbdbd;
}

.mini-tip-dot {
  width: 3rpx;
  height: 3rpx;
  border-radius: 50%;
  background: #6b6b6b;
  display: inline-block;
}

.wheel-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wheel-canvas {
  width: 560rpx;
  height: 560rpx;
}

.spin-btn {
  margin-top: 12rpx;
  width: 300rpx;
  background: #111;
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.spin-btn.spinning {
  background: rgba(0, 0, 0, 0.2);
}

.spin-btn::after {
  border: none;
}

.spin-btn.spinning[disabled] {
  background: rgba(0, 0, 0, 0.2) !important;
  color: #ffffff !important;
  opacity: 1;
}

.share-btn {
  margin-top: 36rpx;
  width: 300rpx;
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.result {
  margin-top: 18rpx;
  text-align: center;
  padding: 10rpx 0;
}

.result-prefix {
  color: #111;
  font-size: 29rpx;
}

.result-color {
  font-size: 29rpx;
}

.share-guide-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 200;
}

.guide-arrow {
  position: absolute;
  top: 30rpx;
  right: 96rpx;
  width: 22rpx;
  height: 22rpx;
  border-top: 3rpx solid #fff;
  border-right: 3rpx solid #fff;
  transform: rotate(-45deg);
}

.guide-text {
  position: absolute;
  top: 86rpx;
  right: 24rpx;
  color: #fff;
  font-size: 28rpx;
  line-height: 1.5;
  max-width: 420rpx;
  text-align: right;
}
