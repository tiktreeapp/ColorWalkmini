page {
  background: #f7f7f7;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
}

.section-title {
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
  display: block;
  color: #111;
}

.wheel-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wheel-canvas {
  width: 560rpx;
  height: 560rpx;
}

.spin-btn {
  margin-top: 12rpx;
  width: 300rpx;
  background: #111;
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.spin-btn.spinning {
  background: rgba(0, 0, 0, 0.2);
}

.spin-btn::after {
  border: none;
}

.spin-btn.spinning[disabled] {
  background: rgba(0, 0, 0, 0.2) !important;
  color: #ffffff !important;
  opacity: 1;
}

.share-btn {
  margin-top: 36rpx;
  width: 300rpx;
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.result {
  margin-top: 18rpx;
  text-align: center;
  padding: 10rpx 0;
}

.result-prefix {
  color: #111;
  font-size: 29rpx;
}

.result-color {
  font-size: 29rpx;
}

.share-guide-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 200;
}

.guide-arrow {
  position: absolute;
  top: 30rpx;
  right: 96rpx;
  width: 22rpx;
  height: 22rpx;
  border-top: 3rpx solid #fff;
  border-right: 3rpx solid #fff;
  transform: rotate(-45deg);
}

.guide-text {
  position: absolute;
  top: 86rpx;
  right: 24rpx;
  color: #fff;
  font-size: 28rpx;
  line-height: 1.5;
  max-width: 420rpx;
  text-align: right;
}
